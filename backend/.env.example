# Copy this to .env and fill in your NeonDB values.
# NEVER commit .env to git.

# NeonDB connection string
DATABASE_URL=jdbc:postgresql://your-neon-host/neondb?sslmode=require
DATABASE_USERNAME=neondb_owner
DATABASE_PASSWORD=your_password_here

# JWT secret key
JWT_SECRET=your-secret-key-here

# CORS allowed origins
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081,http://10.0.2.2:8080

# Paystack secret key (server-side only — NEVER expose this to the frontend).
# Get this from your Paystack dashboard > Settings > API Keys & Webhooks.
# Use a test key (sk_test_...) until you're ready to take real payments.
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Absolute base URL of this backend (including /api), used to build the
# Paystack checkout callback URL. Set this to your deployed Railway domain.
APP_BASE_URL=https://your-railway-domain.up.railway.app/api
