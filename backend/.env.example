# Copy this to .env and fill in your NeonDB values.
# NEVER commit .env to git.

# NeonDB connection string
# Get this from: https://console.neon.tech → your project → Connection Details
DB_URL=jdbc:postgresql://<your-neon-host>/<your-db-name>?sslmode=require
DB_USERNAME=<your-neon-username>
DB_PASSWORD=<your-neon-password>

# JWT — generate a strong random secret (min 32 chars) for production
JWT_SECRET=replace-with-a-strong-random-secret-at-least-256-bits
